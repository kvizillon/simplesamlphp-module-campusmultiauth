{
  "name": "kvizillon/simplesamlphp-module-campusmultiauth",
  "description": "SimpleSAMLphp module which provides password based and federated authentication on single page",
  "type": "simplesamlphp-module",
  "keywords": [
    "simplesamlphp"
  ],
  "license": "BSD-3-Clause",
  "authors": [
    {
      "name": "kvizillon",
      "email": "kvizillon@gmail.com"
    }
  ],
  "require": {
    "php": "^8.0 || ^8.1 || ^8.2 || ^8.3",
    "simplesamlphp/composer-module-installer": "^1.3",
    "simplesamlphp/simplesamlphp": "^2.0",
    "league/commonmark": "^1.0 || ^2.0",
    "ext-intl": "*"
  },
  "config": {
    "allow-plugins": {
      "simplesamlphp/composer-module-installer": true
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "SimpleSAML\\Module\\campusmultiauth\\": "src/"
    }
  },
  "require-dev": {
    "symplify/easy-coding-standard": "^12.0"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}